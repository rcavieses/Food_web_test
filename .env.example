# Configuración de Ollama
# ========================

# URL de la API de Ollama (por defecto: localhost:11434)
# OLLAMA_API_URL=http://localhost:11434/api/generate

# Modelo de Ollama a usar
# Opciones disponibles: nous-hermes2 (⚡ recomendado, más rápido), mistral, llama2, neural-chat, orca-mini
# OLLAMA_MODEL=nous-hermes2

# Timeout en segundos para las respuestas del modelo
# Aumentar si el modelo es muy lento o tienes hardware limitado
# OLLAMA_TIMEOUT=600
